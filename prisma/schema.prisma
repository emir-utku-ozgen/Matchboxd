// Matchboxd - Futbol Müsabakaları Değerlendirme Sistemi
// PostgreSQL (Neon)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String?
  avatarUrl    String?
  favoriteTeam String?
  role         String   @default("user") // user | admin
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  reviews      Review[]
  collections  Collection[]
}

model Match {
  id              String   @id @default(cuid())
  externalId      String?  @unique
  homeTeamName    String
  awayTeamName    String
  homeCrest       String?
  awayCrest       String?
  homeScore       Int
  awayScore       Int
  competition     String
  competitionType String
  season          String
  matchDate       DateTime
  venue           String
  status          String?
  statsJson       String?
  isArchived      Boolean  @default(false)
  likeCount       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  reviews         Review[]
  collectionItems CollectionMatch[]

  @@index([competition])
  @@index([isArchived])
  @@index([season])
}

model Review {
  id                  String   @id @default(cuid())
  matchId             String
  match               Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  userId              String?
  user                User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  userName            String
  title               String?
  content             String
  rating              Int
  formation           String?
  manOfTheMatch       String?
  categoryRatingsJson String?
  weightedRating      Float?
  likeCount           Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([matchId])
  @@index([createdAt])
  @@index([manOfTheMatch])
  @@index([weightedRating])
}

model Collection {
  id          String            @id @default(cuid())
  userId      String
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String?
  isPublic    Boolean           @default(true)
  type        String            @default("CUSTOM")
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  matches     CollectionMatch[]

  @@index([userId])
  @@index([type])
}

model CollectionMatch {
  id           String     @id @default(cuid())
  collectionId String
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  matchId      String
  match        Match      @relation(fields: [matchId], references: [id], onDelete: Cascade)
  addedAt      DateTime   @default(now())

  @@unique([collectionId, matchId])
  @@index([collectionId])
  @@index([matchId])
}
