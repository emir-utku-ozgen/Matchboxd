# Veritabanı (Turso = libsql)
# Turso: libsql://<db-name>-<org>.turso.io
DATABASE_URL=
# Turso auth token (Turso dashboard veya turso db tokens create)
TURSO_AUTH_TOKEN=

# Football-Data.org API (maçları canlı çekmek için)
# Almak için: https://www.football-data.org/client/register
# Detaylı adımlar: docs/API-KEY-SETUP.md
FOOTBALL_DATA_API_KEY=

# Opsiyonel: Hangi ligler çekilsin (virgülle ayır). Boşsa PL,TSL kullanılır.
# FOOTBALL_DATA_COMPETITIONS=PL,TSL

# NextAuth (giriş sistemi)
# Üretmek için: openssl rand -base64 32
NEXTAUTH_SECRET=
# Yerel geliştirme için genelde gerekmez; production'da tam URL (örn. https://matchboxd.vercel.app)
# NEXTAUTH_URL=http://127.0.0.1:3000
