{
  "name": "matchboxd",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "ulimit -n 10000; WATCHPACK_POLLING=true next dev --hostname 127.0.0.1",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "db:push": "prisma db push",
    "db:migrate-deploy": "prisma migrate deploy",
    "db:turso-sql": "prisma migrate diff --from-empty --to-schema prisma/schema.prisma --script -o prisma/turso-schema.sql",
    "db:seed": "tsx prisma/seed.ts",
    "db:archive": "tsx prisma/archive.ts",
    "db:superlig": "tsx prisma/seed-superlig.ts",
    "db:migrate-neon": "tsx scripts/migrate-to-neon.ts",
    "db:drop-null-cols": "tsx scripts/drop-all-null-columns.ts",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@libsql/client": "^0.17.0",
    "@neondatabase/serverless": "^1.1.0",
    "@prisma/adapter-better-sqlite3": "^7.5.0",
    "@prisma/adapter-libsql": "^7.5.0",
    "@prisma/adapter-neon": "^7.8.0",
    "@prisma/client": "^7.5.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.6.2",
    "dotenv": "^17.3.1",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "next-auth": "^4.24.13",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.8.1",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "prisma": "^7.5.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
